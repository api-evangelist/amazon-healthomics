{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-healthomics/refs/heads/main/json-schema/healthomics-start-reference-import-job-response-schema.json",
  "name": "StartReferenceImportJobResponse",
  "type": "object",
  "required": [
    "id",
    "referenceStoreId",
    "roleArn",
    "status",
    "creationTime"
  ],
  "properties": {
    "id": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ImportJobId"
        },
        {
          "description": "The job's ID."
        }
      ]
    },
    "referenceStoreId": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ReferenceStoreId"
        },
        {
          "description": "The job's reference store ID."
        }
      ]
    },
    "roleArn": {
      "allOf": [
        {
          "$ref": "#/components/schemas/RoleArn"
        },
        {
          "description": "The job's service role ARN."
        }
      ]
    },
    "status": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ReferenceImportJobStatus"
        },
        {
          "description": "The job's status."
        }
      ]
    },
    "creationTime": {
      "allOf": [
        {
          "$ref": "#/components/schemas/SyntheticTimestamp_date_time"
        },
        {
          "description": "When the job was created."
        }
      ]
    }
  }
}