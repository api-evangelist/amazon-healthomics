{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-healthomics/refs/heads/main/json-schema/healthomics-list-sequence-stores-response-schema.json",
  "title": "ListSequenceStoresResponse",
  "type": "object",
  "required": [
    "sequenceStores"
  ],
  "properties": {
    "nextToken": {
      "allOf": [
        {
          "$ref": "#/components/schemas/NextToken"
        },
        {
          "description": "A pagination token that's included if more results are available."
        }
      ]
    },
    "sequenceStores": {
      "allOf": [
        {
          "$ref": "#/components/schemas/SequenceStoreDetailList"
        },
        {
          "description": "A list of sequence stores."
        }
      ]
    }
  }
}