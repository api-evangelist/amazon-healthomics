  "title": "ListAnnotationStoresRequest",
  "type": "object",
  "properties": {
    "ids": {
      "allOf": [
        {
          "$ref": "#/components/schemas/ListAnnotationStoresRequestIdsList"
        },
        {
          "description": "IDs of stores to list."
